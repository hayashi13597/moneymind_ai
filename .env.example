# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/money_mind_ai?schema=public"

# Better Auth email/password runtime setup.
BETTER_AUTH_SECRET="replace-with-a-random-secret-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:3000"

# Resend transactional email setup.
RESEND_API_KEY=
EMAIL_FROM="MoneyMind AI <no-reply@example.com>"
